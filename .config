#
# Automatically generated file - 适用于RAX3000Q的iStoreOS配置 (OpenWrt 23.05)
# GitHub Actions 自动编译配置
# 目标: CMCC RAX3000Q (ipq50xx/ipq5018, 256MB内存, NAND闪存)
# 管理地址: 192.168.66.1
# 固件格式: sysupgrade.bin + factory.ubi + ubifs.img
#

# ============= 目标平台 =============
CONFIG_TARGET_ipq50xx=y
CONFIG_TARGET_ipq50xx_arm=y
CONFIG_TARGET_ipq50xx_arm_DEVICE_cmcc_rax3000q=y
CONFIG_TARGET_ARCH_PACKAGES="arm_cortex-a7_neon-vfpv4"
CONFIG_CPU_TYPE="cortex-a7+neon-vfpv4"
CONFIG_ARCH_IPQ256M=y
CONFIG_SKB_FIXED_SIZE_2K=y

# ============= 内核版本 =============
CONFIG_LINUX_5_15=y
CONFIG_KERNEL_XZ=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_LD_DEAD_CODE_DATA_ELIMINATION=y

# ============= 基础系统设置 =============
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y
CONFIG_IPV6=y
CONFIG_PREEMPT=y
CONFIG_SWAP=y
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# ============= 镜像格式配置（生成三种格式）=============
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_TARGET_ROOTFS_UBIFS=y
CONFIG_TARGET_UBIFS_FREE_SPACE_FIXUP=y
CONFIG_TARGET_UBI=y
CONFIG_TARGET_UBIFS_MAXLEBCNT=2048
CONFIG_TARGET_UBIFS_COMPRESSION_LZO=y
CONFIG_IMAGEOPT=y
CONFIG_TARGET_ALL_PROFILES=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_IMAGES_PAD=y
CONFIG_TARGET_IMAGE_NAND=y

# ============= 网络设置 =============
CONFIG_TARGET_PREINIT_IP="192.168.66.1"
CONFIG_TARGET_PREINIT_NETMASK="255.255.255.0"
CONFIG_TARGET_PREINIT_BROADCAST="192.168.66.255"

# ============= 分区和文件系统 =============
CONFIG_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_SPLIT_FIT_FW=y
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_kmod-nand=y
CONFIG_PACKAGE_kmod-nand-core=y
CONFIG_PACKAGE_kmod-mtd-nand-ipq40xx=y

# ============= 核心系统组件 =============
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_libc=y
CONFIG_PACKAGE_libgcc=y
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_ubox=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_ubusd=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_logd=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_urandom-seed=y
CONFIG_PACKAGE_urngd=y
CONFIG_PACKAGE_usign=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_jshn=y
CONFIG_PACKAGE_libjson-script=y
CONFIG_PACKAGE_fstools=y
CONFIG_FSTOOLS_UBIFS_EXTROOT=y

# ============= 网络基础服务 =============
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_ip-tiny=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_ip6tables-mod-nat=y
